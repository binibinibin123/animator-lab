# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Auth
AUTH_SECRET=replace-with-a-long-random-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# AI providers
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
FAL_KEY=
ELEVENLABS_API_KEY=

# Optional local generation
COMFYUI_BASE_URL=http://127.0.0.1:8188

# Credits / local development
LOCAL_API_AUTH=optional
DEFAULT_PROJECT_CREDITS=3000
TTS_CREDITS_PER_1K_CHARS=20
TTS_MIN_CREDITS_PER_REQUEST=1

# Optional bot integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
